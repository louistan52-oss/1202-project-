{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\main.exe",
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\BMS_L.cpp",
                "${fileDirname}\\BMS_U.cpp",
                "${fileDirname}\\Users.cpp",
                "${fileDirname}\\User_data.cpp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: cl.exe"
        }
    ]
}